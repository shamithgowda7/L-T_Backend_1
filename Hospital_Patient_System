// --- Task 11: Calculate a Derived Value ---
console.log("--- Task 11 ---");
function checkMinorOrAdult(patientObj) {
  if (patientObj.age < 18) {
    return `${patientObj.name} is a Minor.`;
  } else {
    return `${patientObj.name} is an Adult.`;
  }
}

console.log(checkMinorOrAdult({ name: "Tom", age: 12 }));
console.log(checkMinorOrAdult({ name: "Martha", age: 28 }));
console.log();

// --- Task 12: Arrow Function Version ---
console.log("--- Task 12 ---");
const checkMinorOrAdultArrow = (name, age) =>
  age < 18 ? `${name} is a Minor.` : `${name} is an Adult.`;

console.log(checkMinorOrAdultArrow("Lucas", 15));
console.log(checkMinorOrAdultArrow("Veronica", 50));
console.log();

