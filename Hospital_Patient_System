// --- Task 5: Classify a Record ---
console.log("--- Task 5 ---");
let checkAge = 65;

if (checkAge >= 60) {
  console.log(`Patient age (${checkAge}): Senior Citizen Priority`);
} else if (checkAge >= 18) {
  console.log(`Patient age (${checkAge}): Adult Patient`);
} else {
  console.log(`Patient age (${checkAge}): Pediatric Patient`);
}
console.log();

// --- Task 6: Iterate Over Records ---
console.log("--- Task 6 ---");
let patients = [
  { id: 101, name: "Connor", age: 17, disease: "Fever" },
  { id: 102, name: "Ronaldo", age: 62, disease: "Hypertension" },
  { id: 103, name: "Charlie puth", age: 34, disease: "Fracture" },
  { id: 104, name: "Prince Rambo", age: 70, disease: "Diabetes" },
];

console.log("Patient Records:");
for (let i = 0; i < patients.length; i++) {
  console.log(
    `ID: ${patients[i].id}, Name: ${patients[i].name}, Age: ${patients[i].age}, Condition: ${patients[i].disease}`,
  );
}
console.log();

// --- Task 7: Skip or Stop Early ---
console.log("--- Task 7 ---");
console.log("Loop with 'continue' (Skipping patients under 18):");
for (let patient of patients) {
  if (patient.age < 18) {
    continue;
  }
  console.log(`Adult/Senior Patient: ${patient.name} (Age: ${patient.age})`);
}

console.log("\nLoop with 'break' (Stop loop when a patient over 65 is found):");
for (let patient of patients) {
  if (patient.age > 65) {
    console.log(
      `Senior citizen found above 65: ${patient.name}. Stopping search.`,
    );
    break;
  }
  console.log(`Checking patient: ${patient.name}`);
}
console.log();

// --- Task 8: Add & Find ---
console.log("--- Task 8 ---");
// Adding new patients push()
patients.push({ id: 105, name: "Harry", age: 29, disease: "Cancer" });
console.log("Added new patient using push(). Total count:", patients.length);

// Finding patients with the highest age
let oldestPatient = patients[0];
for (let i = 1; i < patients.length; i++) {
  if (patients[i].age > oldestPatient.age) {
    oldestPatient = patients[i];
  }
}
console.log(
  `Oldest Patient: ${oldestPatient.name} with age ${oldestPatient.age}`,
);
console.log();

// --- Task 9: Remove & Sort ---
console.log("--- Task 9 ---");
// Removing the last entry using pop()
let removedPatient = patients.pop();
console.log(`Removed last patient using pop(): ${removedPatient.name}`);

// Sorting patients array by age (ascending order)
patients.sort((a, b) => a.age - b.age);
console.log("Patients sorted by age (ascending):", patients);
console.log();

